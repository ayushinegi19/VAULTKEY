# Copy this file to .env and fill in real values. Never commit .env.

# Postgres connection string
# Example (local): postgres://postgres:postgres@localhost:5432/vaultkey
DATABASE_URL=postgres://postgres:postgres@localhost:5432/vaultkey

# Secret used to sign JWTs. Use a long random string in production.
JWT_SECRET=replace-with-a-long-random-string

# 32-byte (256-bit) master key, hex-encoded, used to encrypt/wrap per-secret data keys
# (envelope encryption). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_KEY=replace-with-64-hex-characters

# Port the server listens on
PORT=3000
